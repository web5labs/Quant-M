fast_core_onboard() {
  echo "Quant-M fast core onboarding"
  echo "No Rust core compile is required for this setup step."
  echo

  local workspace
  workspace="$(prompt_with_default "Workspace path" "./workspace")"
  workspace="$(normalize_workspace_path "$workspace")"

  local profile_choice profile
  profile_choice="$(prompt_choice "Device profile" "1" "Raspberry Pi / edge core" "Laptop/desktop core" "VPS/server core")"
  case "$profile_choice" in
    1) profile="edge" ;;
    2) profile="laptop" ;;
    3) profile="vps" ;;
    *) profile="edge" ;;
  esac

  local network_choice external_network
  network_choice="$(prompt_choice "Network posture" "1" "Local only" "Ask before network/live checks" "Allow provider checks")"
  case "$network_choice" in
    3) external_network=true ;;
    *) external_network=false ;;
  esac

  local codex_choice codex_enabled
  codex_choice="$(prompt_choice "Recognize Codex CLI if installed?" "2" "Yes" "No")"
  case "$codex_choice" in
    1) codex_enabled=true ;;
    *) codex_enabled=false ;;
  esac

  local guardian_choice guardian_enabled
  guardian_choice="$(prompt_choice "Enable context guardian handoff files?" "1" "Yes" "No")"
  case "$guardian_choice" in
    2) guardian_enabled=false ;;
    *) guardian_enabled=true ;;
  esac

  mkdir -p "$APP_DIR/$workspace"/{memory,daily,queue,logs,skills,state/sessions,state/context-guardian,state/shared}
  touch "$APP_DIR/$workspace/MEMORY.md" "$APP_DIR/$workspace/HEARTBEAT.md"
  write_fast_onboarding_config "$workspace" "$profile" "$external_network" "$codex_enabled" "$guardian_enabled"

  cat <<EOF

Fast onboarding complete.
config: $APP_DIR/quant-m.toml
workspace: $APP_DIR/$workspace
runtime_profile: $profile
external_network_enabled: $external_network
codex_tool_enabled: $codex_enabled

Next, when you are ready to compile the core:
  ./quantm core-build

Then start the pairing server:
  ./quantm core pair serve --bind 0.0.0.0:8787
EOF
}

ensure_release_child_feature() {
  if ! grep -q '^child-min =' "$APP_DIR/Cargo.toml"; then
    cat >&2 <<'EOF'
This checkout does not contain the v0.local-alpha child-min feature.

Run:
  git fetch origin
  git checkout release/v0-local-alpha
  git pull origin release/v0-local-alpha
EOF
    exit 2
  fi
}

child_needs_build() {
  [[ ! -x "$CHILD_BIN" ]] && return 0
  [[ -n "$(find "$APP_DIR/src/bin/quant-m-child.rs" "$APP_DIR/src/device_telemetry.rs" "$APP_DIR/Cargo.toml" "$APP_DIR/Cargo.lock" -newer "$CHILD_BIN" -print -quit)" ]]
}

core_needs_build() {
  [[ ! -x "$CORE_BIN" ]] && return 0
  [[ -n "$(find "$APP_DIR/src" "$APP_DIR/Cargo.toml" "$APP_DIR/Cargo.lock" -newer "$CORE_BIN" -print -quit)" ]]
}

build_child() {
  ensure_release_child_feature
  if child_needs_build; then
    echo "Building Quant-M child locally..."
    CARGO_BUILD_JOBS="${CARGO_BUILD_JOBS:-1}" cargo build \
      --manifest-path "$APP_DIR/Cargo.toml" \
      --profile release-child \
      --bin quant-m-child \
      --no-default-features \
      --features child-min
  fi
}

build_core() {
  if core_needs_build; then
    echo "Building Quant-M core locally with core-full..."
    CARGO_BUILD_JOBS="${CARGO_BUILD_JOBS:-1}" cargo build \
      --manifest-path "$APP_DIR/Cargo.toml" \
      --bin quant-m \
      --features core-full
  fi
}

case "${1:-}" in
  onboard)
    if [[ ! -x "$CORE_BIN" || "${QUANTM_FAST_ONBOARD:-}" == "1" ]]; then
      fast_core_onboard
      exit 0
    fi
    ;;
  core-build)
    build_core
    echo "Core binary ready: $CORE_BIN"
    exit 0
    ;;
  core-onboard)
    build_core
    exec "$CORE_BIN" onboard
    ;;
  child-build|edge-build)
    build_child
    echo "Child binary ready: $CHILD_BIN"
    exit 0
    ;;
  child|edge)
    shift
    build_child
    if [[ "$#" -eq 0 ]]; then
      exec "$CHILD_BIN" --help
    fi
    exec "$CHILD_BIN" "$@"
    ;;
  core)
    shift
    build_core
    if [[ "$#" -eq 0 ]]; then
      exec "$CORE_BIN" start
    fi
    exec "$CORE_BIN" "$@"
    ;;
  edge-help|child-help)
    print_edge_help
    exit 0
    ;;
esac

if is_edge_device && [[ "$#" -eq 0 ]]; then
  print_edge_help
  exit 0
fi

build_core

if [[ "$#" -eq 0 ]]; then
  exec "$CORE_BIN" start
fi

exec "$CORE_BIN" "$@"
