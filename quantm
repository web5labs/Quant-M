#!/usr/bin/env bash
set -euo pipefail

APP_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CORE_BIN="$APP_DIR/target/debug/quant-m"
CHILD_BIN="$APP_DIR/target/release-child/quant-m-child"

is_edge_device() {
  if [[ "${QUANTM_ASSUME_EDGE:-}" == "1" ]]; then
    return 0
  fi
  if [[ -f /boot/dietpi/.version || -f /boot/dietpi/.install_stage ]]; then
    return 0
  fi
  if [[ -r /proc/device-tree/model ]] && tr -d '\0' < /proc/device-tree/model | grep -qi "raspberry pi"; then
    return 0
  fi
  if [[ -n "${TERMUX_VERSION:-}" || -d /data/data/com.termux/files/usr ]]; then
    return 0
  fi
  return 1
}

print_edge_help() {
  cat <<'EOF'
Quant-M edge-device setup detected.

For v0.local-alpha hardware smoke, decide whether this device is the core
or a child worker.

Core/onboarding commands:
  ./quantm onboard
  ./quantm core pair serve --bind 0.0.0.0:8787

Child/worker commands:
  ./quantm child-build
  ./quantm child --help
  ./quantm child doctor
  ./quantm child pair --core http://<core-lan-ip>:8787 --invite <invite-token>
  ./quantm child heartbeat

Safety: child mode builds quant-m-child with child-min only. It does not enable
provider calls, proposals, execution, trading, betting, or canonical writes.
EOF
}

prompt_with_default() {
  local prompt="$1"
  local default="$2"
  local answer=""
  if [[ "${QUANTM_ONBOARD_NONINTERACTIVE:-}" == "1" ]]; then
    printf "%s\n" "$default"
    return 0
  fi
  printf "%s [%s]: " "$prompt" "$default" >&2
  read -r answer || answer=""
  if [[ -z "$answer" ]]; then
    answer="$default"
  fi
  printf "%s\n" "$answer"
}

prompt_choice() {
  local prompt="$1"
  local default="$2"
  shift 2
  local answer=""
  if [[ "${QUANTM_ONBOARD_NONINTERACTIVE:-}" == "1" ]]; then
    printf "%s\n" "$default"
    return 0
  fi
  printf "%s\n" "$prompt" >&2
  local index=1
  for choice in "$@"; do
    printf "  %s) %s\n" "$index" "$choice" >&2
    index=$((index + 1))
  done
  printf "Choose [%s]: " "$default" >&2
  read -r answer || answer=""
  if [[ -z "$answer" ]]; then
    answer="$default"
  fi
  printf "%s\n" "$answer"
}

normalize_workspace_path() {
  local value="$1"
  if [[ "$value" == "/" || "$value" =~ ^/[^/]+$ ]]; then
    echo "Refusing workspace '$value'. Use ./workspace or an app-owned path like /root/Quant-M/workspace." >&2
    exit 2
  fi
  printf "%s\n" "$value"
}

write_fast_onboarding_config() {
  local workspace="$1"
  local profile="$2"
  local external_network="$3"
  local codex_enabled="$4"
  local guardian_enabled="$5"

  cat > "$APP_DIR/quant-m.toml" <<EOF
