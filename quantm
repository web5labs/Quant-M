#!/usr/bin/env bash
set -euo pipefail

APP_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CORE_BIN="$APP_DIR/target/debug/quant-m"
CHILD_BIN="$APP_DIR/target/release-child/quant-m-child"

is_edge_device() {
  if [[ "${QUANTM_ASSUME_EDGE:-}" == "1" ]]; then
    return 0
  fi
  if [[ -f /boot/dietpi/.version || -f /boot/dietpi/.install_stage ]]; then
    return 0
  fi
  if [[ -r /proc/device-tree/model ]] && tr -d '\0' < /proc/device-tree/model | grep -qi "raspberry pi"; then
    return 0
  fi
  if [[ -n "${TERMUX_VERSION:-}" || -d /data/data/com.termux/files/usr ]]; then
    return 0
  fi
  return 1
}

print_edge_help() {
  cat <<'EOF'
Quant-M edge-device setup detected.

For v0.local-alpha hardware smoke, decide whether this device is the core
or a child worker.

Core/onboarding commands:
  ./quantm onboard
  ./quantm core pair serve --bind 0.0.0.0:8787

Child/worker commands:
  ./quantm child-build
  ./quantm child --help
  ./quantm child doctor
  ./quantm child pair --core http://<core-lan-ip>:8787 --invite <invite-token>
  ./quantm child heartbeat

Safety: child mode builds quant-m-child with child-min only. It does not enable
provider calls, proposals, execution, trading, betting, or canonical writes.
EOF
}

ensure_release_child_feature() {
  if ! grep -q '^child-min =' "$APP_DIR/Cargo.toml"; then
    cat >&2 <<'EOF'
This checkout does not contain the v0.local-alpha child-min feature.

Run:
  git fetch origin
  git checkout release/v0-local-alpha
  git pull origin release/v0-local-alpha
EOF
    exit 2
  fi
}

child_needs_build() {
  [[ ! -x "$CHILD_BIN" ]] && return 0
  [[ -n "$(find "$APP_DIR/src/bin/quant-m-child.rs" "$APP_DIR/src/device_telemetry.rs" "$APP_DIR/Cargo.toml" "$APP_DIR/Cargo.lock" -newer "$CHILD_BIN" -print -quit)" ]]
}

core_needs_build() {
  [[ ! -x "$CORE_BIN" ]] && return 0
  [[ -n "$(find "$APP_DIR/src" "$APP_DIR/Cargo.toml" "$APP_DIR/Cargo.lock" -newer "$CORE_BIN" -print -quit)" ]]
}

build_child() {
  ensure_release_child_feature
  if child_needs_build; then
    echo "Building Quant-M child locally..."
    CARGO_BUILD_JOBS="${CARGO_BUILD_JOBS:-1}" cargo build \
      --manifest-path "$APP_DIR/Cargo.toml" \
      --profile release-child \
      --bin quant-m-child \
      --no-default-features \
      --features child-min
  fi
}

build_core() {
  if core_needs_build; then
    echo "Building Quant-M core locally with core-full..."
    CARGO_BUILD_JOBS="${CARGO_BUILD_JOBS:-1}" cargo build \
      --manifest-path "$APP_DIR/Cargo.toml" \
      --bin quant-m \
      --features core-full
  fi
}

case "${1:-}" in
  core-build)
    build_core
    echo "Core binary ready: $CORE_BIN"
    exit 0
    ;;
  core-onboard)
    build_core
    exec "$CORE_BIN" onboard
    ;;
  child-build|edge-build)
    build_child
    echo "Child binary ready: $CHILD_BIN"
    exit 0
    ;;
  child|edge)
    shift
    build_child
    if [[ "$#" -eq 0 ]]; then
      exec "$CHILD_BIN" --help
    fi
    exec "$CHILD_BIN" "$@"
    ;;
  core)
    shift
    build_core
    if [[ "$#" -eq 0 ]]; then
      exec "$CORE_BIN" start
    fi
    exec "$CORE_BIN" "$@"
    ;;
  edge-help|child-help)
    print_edge_help
    exit 0
    ;;
esac

if is_edge_device && [[ "$#" -eq 0 ]]; then
  print_edge_help
  exit 0
fi

build_core

if [[ "$#" -eq 0 ]]; then
  exec "$CORE_BIN" start
fi

exec "$CORE_BIN" "$@"
