{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://the-staff.local/ponboarding/contracts/model-stack-recommendation.schema.json",
  "title": "PONboarding Model Stack Recommendation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "benchmarkSources",
    "weights",
    "laneRecommendations"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "benchmarkSources": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "weights": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "benchmarkScore",
        "reasoningFit",
        "codeFit",
        "toolUseFit",
        "modalityFit",
        "latencyFit",
        "costEfficiency",
        "providerReliability"
      ],
      "properties": {
        "benchmarkScore": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "reasoningFit": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "codeFit": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "toolUseFit": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "modalityFit": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "latencyFit": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "costEfficiency": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "providerReliability": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "laneRecommendations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "lane",
          "objective",
          "recommendedModels",
          "fallbackModelIds",
          "reviewOwner"
        ],
        "properties": {
          "lane": {
            "type": "string",
            "enum": [
              "research",
              "product",
              "ui-ux",
              "backend",
              "implementation",
              "audit"
            ]
          },
          "objective": {
            "type": "string"
          },
          "recommendedModels": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "modelId",
                "provider",
                "dimensionScores",
                "weightedScore",
                "selectionReason"
              ],
              "properties": {
                "modelId": {
                  "type": "string"
                },
                "provider": {
                  "type": "string"
                },
                "homepageUrl": {
                  "type": "string",
                  "format": "uri"
                },
                "docsUrl": {
                  "type": "string",
                  "format": "uri"
                },
                "apiKeyUrl": {
                  "type": "string",
                  "format": "uri"
                },
                "modalities": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "supportedParameters": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "dimensionScores": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "benchmarkScore",
                    "reasoningFit",
                    "codeFit",
                    "toolUseFit",
                    "modalityFit",
                    "latencyFit",
                    "costEfficiency",
                    "providerReliability"
                  ],
                  "properties": {
                    "benchmarkScore": {
                      "type": "number",
                      "minimum": 0,
                      "maximum": 1
                    },
                    "reasoningFit": {
                      "type": "number",
                      "minimum": 0,
                      "maximum": 1
                    },
                    "codeFit": {
                      "type": "number",
                      "minimum": 0,
                      "maximum": 1
                    },
                    "toolUseFit": {
                      "type": "number",
                      "minimum": 0,
                      "maximum": 1
                    },
                    "modalityFit": {
                      "type": "number",
                      "minimum": 0,
                      "maximum": 1
                    },
                    "latencyFit": {
                      "type": "number",
                      "minimum": 0,
                      "maximum": 1
                    },
                    "costEfficiency": {
                      "type": "number",
                      "minimum": 0,
                      "maximum": 1
                    },
                    "providerReliability": {
                      "type": "number",
                      "minimum": 0,
                      "maximum": 1
                    }
                  }
                },
                "weightedScore": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1
                },
                "selectionReason": {
                  "type": "string"
                }
              }
            }
          },
          "fallbackModelIds": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "reviewOwner": {
            "type": "string"
          }
        }
      }
    }
  }
}
